{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "UTDE",
  "version": "0.1.0",
  "identifier": "io.utde.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "UTDE — Universal Toolpath Design Environment",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/utde-server"
    ],
    "publisher": "UTDE Contributors",
    "category": "DeveloperTool",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
