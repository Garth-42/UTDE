# Keep the build context small. The image bakes the toolchain and clones the
# repo at runtime (see entrypoint.sh), so the build itself only needs
# utde_v0.1.0/, docs/requirements.txt, and entrypoint.sh — nothing else here
# needs to be uploaded to the Docker daemon.

.git
.github

# Node / frontend (installed on the pod, not at build time)
**/node_modules
utde-app/dist
utde-app/src-tauri/target

# Python caches and editable-install metadata
**/__pycache__
**/*.py[cod]
**/*.egg-info
.pytest_cache
venv
.venv

# Desktop / docs build outputs
dist
build
site
*.spec.bak

# Local tooling / secrets
.claude
.env
.env.local
logs

# OS cruft
.DS_Store

# CAD test fixtures (also gitignored)
*.step
*.stp
*.STEP
*.STP
